# All keys are OPTIONAL — the scanner degrades gracefully without them.

# Anthropic API key: enables the plain-English AI explanation layer.
ANTHROPIC_API_KEY=

# Etherscan V2 key (one key, 50+ chains): enables source-verification + deployer checks on EVM.
ETHERSCAN_API_KEY=

# Helius key: better Solana RPC (falls back to public mainnet RPC without it).
HELIUS_API_KEY=

# RugCheck API key (optional cross-check on Solana).
RUGCHECK_API_KEY=

# Server
PORT=3000
HOST=127.0.0.1
# Public base URL used in permalinks/OG tags (set to your domain in prod)
PUBLIC_BASE_URL=http://127.0.0.1:3000
