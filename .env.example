# Copy to .env and fill in. All API keys are OPTIONAL — the scanner degrades
# gracefully without them (scans just come back "partial").

# ── recommended before launch ─────────────────────────────────────────
# Etherscan V2 key (one key, 50+ chains): unlocks source-verification + deployer
# checks on EVM. Without it, EVM source is "unverified" and the AI layer is skipped.
ETHERSCAN_API_KEY=

# Helius key: reliable Solana RPC (falls back to the throttled public RPC without it).
HELIUS_API_KEY=

# Anthropic API key: enables the plain-English AI explanation layer.
ANTHROPIC_API_KEY=

# ── optional ──────────────────────────────────────────────────────────
# RugCheck API key (optional cross-check on Solana).
RUGCHECK_API_KEY=

# ── deployment (Cloudflare Tunnel) ────────────────────────────────────
# Token for the tunnel you create in Cloudflare (Zero Trust > Networks > Tunnels).
# cloudflared uses it to connect the droplet to Cloudflare — no inbound ports.
CLOUDFLARE_TUNNEL_TOKEN=
# Your public URL = the tunnel's hostname. Used in permalinks + share cards, so
# shared screenshots show your domain (not localhost).
PUBLIC_BASE_URL=https://scanner.example.com

# ── server ────────────────────────────────────────────────────────────
PORT=3000
# Local dev: 127.0.0.1. In Docker this is overridden to 0.0.0.0 by compose.
HOST=127.0.0.1
